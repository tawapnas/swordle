# Copy to .env.local and fill in. .env.local is gitignored.
#
# Supabase — from your project dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Service-role key — SERVER ONLY. Never expose to the browser, never prefix with
# NEXT_PUBLIC_. Used by the /admin dashboard to read across all users.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Comma-separated list of emails allowed to view /admin.
ADMIN_EMAILS=you@example.com
